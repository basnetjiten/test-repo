# LightRAG examples — environment template
# Copy to .env and fill in your values.

# Base URL of the running LightRAG server
LIGHTRAG_BASE_URL=http://localhost:9621

# API key — must match LIGHTRAG_API_KEY in the server's .env
LIGHTRAG_API_KEY=replace_with_your_api_key

# OpenAI key — only needed for 04_openai_sdk_demo.py
OPENAI_API_KEY=replace_with_your_openai_api_key
