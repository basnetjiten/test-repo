# lightrag-server standalone environment template
# Copy to `.env` and replace all `replace_with_*` values before deployment.
# For v1.5.0rc2+ — OpenAI mode (default)

###########################
### Image and runtime
###########################
LIGHTRAG_IMAGE=ghcr.io/hkuds/lightrag:v1.5.0rc2
PORT=9621
WORKERS=2
TIMEOUT=180
LOG_LEVEL=INFO

########################################
### Host exposure and shared network
########################################
# 127.0.0.1 = local-only; 0.0.0.0 = LAN/public (use reverse proxy + auth)
LIGHTRAG_HOST_BIND=127.0.0.1
POSTGRES_HOST_BIND=127.0.0.1
PROXY_HOST_BIND=127.0.0.1

# Docker network name other projects can join
LIGHTRAG_NETWORK_NAME=lightrag-shared

############################
### Security and auth
############################
# X-API-Key for programmatic access. Generate with: openssl rand -hex 24
LIGHTRAG_API_KEY=replace_with_strong_api_key

# Paths exempt from API-key check
WHITELIST_PATHS=/health

# Web UI login. Keep quoted to preserve $ in bcrypt hashes.
# Generate bcrypt: lightrag-hash-password --username admin
AUTH_ACCOUNTS='admin:change_this_password'

# JWT signing key (generate with: openssl rand -hex 48)
TOKEN_SECRET=replace_with_long_random_secret
TOKEN_EXPIRE_HOURS=4

############################
### Server and UI
############################
WORKSPACE=default
WEBUI_TITLE=EBProcess LightRAG
WEBUI_DESCRIPTION=Standalone LightRAG server for EBProcess
SUMMARY_LANGUAGE=English
OLLAMA_EMULATING_MODEL_TAG=latest

# Optional browser CORS allowlist. Leave empty for same-origin use.
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080

########################################
### Document / pipeline configuration
########################################
LIGHTRAG_PARSER=*:native-teP;*:legacy-R
ENTITY_EXTRACTION_USE_JSON=true
MAX_PARALLEL_INSERT=4
MAX_ASYNC_LLM=8
MAX_ASYNC_RERANK=8
RERANK_TIMEOUT=30
MAX_UPLOAD_SIZE=104857600
VLM_PROCESS_ENABLE=false

###########################################################################
### LLM Configuration — OpenAI (default)
###########################################################################
LLM_BINDING=openai
LLM_BINDING_HOST=https://api.openai.com/v1
LLM_BINDING_API_KEY=replace_with_openai_api_key
LLM_MODEL=gpt-4.1-mini

# Optional role-specific model overrides
EXTRACT_LLM_MODEL=gpt-4.1-mini
KEYWORD_LLM_MODEL=gpt-4.1-nano
QUERY_LLM_MODEL=gpt-4.1-mini

# --- Alternative: Ollama (local, activate with --profile local-llm) ---
# LLM_BINDING=ollama
# LLM_BINDING_HOST=http://ollama:11434
# LLM_MODEL=mistral-nemo:latest
# OLLAMA_LLM_NUM_CTX=16384
# EXTRACT_LLM_MODEL=mistral-nemo:latest
# KEYWORD_LLM_MODEL=mistral-nemo:latest
# QUERY_LLM_MODEL=mistral-nemo:latest

#######################################################################################
### Embedding Configuration — OpenAI (default)
### IMPORTANT: Do NOT change after the first file is processed without clearing data.
#######################################################################################
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://api.openai.com/v1
EMBEDDING_BINDING_API_KEY=replace_with_openai_api_key
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072
EMBEDDING_TOKEN_LIMIT=8192
EMBEDDING_SEND_DIM=false
EMBEDDING_USE_BASE64=true

# --- Alternative: Ollama embedding ---
# EMBEDDING_BINDING=ollama
# EMBEDDING_BINDING_HOST=http://ollama:11434
# EMBEDDING_MODEL=bge-m3:latest
# EMBEDDING_DIM=1024
# OLLAMA_EMBEDDING_NUM_CTX=8192

######################################
### Rerank configuration (optional)
######################################
RERANK_BINDING=null
# RERANK_BINDING=cohere
# RERANK_MODEL=rerank-v3.5
# RERANK_BINDING_HOST=https://api.cohere.com/v2/rerank
# RERANK_BINDING_API_KEY=replace_with_rerank_api_key

############################
### Storage selection
############################
# KV, doc-status, vector → Postgres
LIGHTRAG_KV_STORAGE=PGKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage
LIGHTRAG_VECTOR_STORAGE=PGVectorStorage

# Graph → NetworkX (file-based, no extra container required)
# Switch to Neo4JStorage or MemgraphStorage for production graph workloads.
LIGHTRAG_GRAPH_STORAGE=NetworkXStorage

############################
### Postgres storage
############################
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=lightrag
POSTGRES_PASSWORD=replace_with_strong_postgres_password
POSTGRES_DATABASE=lightrag
POSTGRES_DB=lightrag
POSTGRES_WORKSPACE=lightrag
POSTGRES_EXPOSED_PORT=5441
# HNSW_HALFVEC saves ~50% memory for 3072-dim OpenAI embeddings
POSTGRES_VECTOR_INDEX_TYPE=HNSW_HALFVEC

############################
### Optional local Ollama profile
### (activate with: docker compose --profile local-llm up -d)
############################
OLLAMA_HOST_BIND=127.0.0.1
OLLAMA_EXPOSED_PORT=11434

############################
### Optional proxy profile
### (activate with: docker compose --profile proxy up -d)
############################
LIGHTRAG_PROXY_PORT=8080
