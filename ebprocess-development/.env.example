# ── Platform APIs & AI Keys ──────────────────────────────────────────────────
# OpenCode API configuration
OPENCODE_API_KEY=your_opencode_api_token_here
OPENCODE_MODEL=claude-3-5-sonnet
OPENCODE_BIN=opencode
OPENCODE_SERVER_URL=http://localhost:4096

# Provider LLM API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_GENERATIVE_AI_API_KEY=your_google_generative_ai_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Figma developer API keys
FIGMA_PAT=your_figma_personal_access_token_here

# LightRAG database configuration
LIGHTRAG_BASE_URL=http://localhost:9621
LIGHTRAG_API_KEY=rH8Q1J6mWKNS1sREkzp3b2Yh79FpHjhA

# ── Git & Repository Configuration ───────────────────────────────────────────
# Generic git settings
GIT_USER=your_git_username
GIT_TOKEN=your_git_token_or_pat
GIT_USER_EMAIL=bot@ebprocess.local

# GitHub configuration
GITHUB_USER=your_github_username
GITHUB_TOKEN=your_github_token_or_pat

# Bitbucket configuration
BITBUCKET_USERNAME=your_bitbucket_username
BITBUCKET_APP_PASSWORD=your_bitbucket_app_password
BITBUCKET_REPO_URL=https://api.bitbucket.org

# ── Database & State Storage ──────────────────────────────────────────────────
# PostgreSQL database url for job and session storage
POSTGRES_URL=your_postres_url

# ── Workspace Directories ──────────────────────────────────────────────────────
# Path to code workspaces (checked out by prepare node)
WORKSPACE_DIR=./workspace
OPENCODE_PROJECT_DIR=./.opencode

# ── Orchestrator Options ──────────────────────────────────────────────────────
# Maximum automatic code repair iterations on node failures
MAX_REPAIR_ITERATIONS=3

# ── Sentry Monitoring & Telemetry ─────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENV=development
SENTRY_TRACES_SAMPLE_RATE=0.1
